NODE_ENV=development
PORT=3009
MONGO_URI=
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3009,http://localhost:5173
TRUST_PROXY=false
RATE_LIMIT_STORE=mongo

# Cookie auth (recommended defaults if frontend is on a different domain)
COOKIE_SAMESITE=none
COOKIE_SECURE=true

# CSRF
CSRF_COOKIE_NAME=csrfToken

# Use JWT_SECRET for quick dev, or set access/refresh separately
JWT_SECRET=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Production hardening (recommended)
# - Set issuer/audience and use separate secrets for access/refresh
# - For key rotation, provide comma-separated secrets (first is used for signing)
JWT_ISSUER=
JWT_AUDIENCE=
JWT_ACCESS_SECRETS=
JWT_REFRESH_SECRETS=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email verification (Gmail SMTP with 2FA App Password)
# 1) Enable 2-Step Verification on the Gmail account
# 2) Create an "App Password" and use it below (not your normal password)
EMAIL_PROVIDER=gmail
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_FROM=No Reply <your_gmail_address@gmail.com>

# Public base URL of this backend (used to generate verification links)
API_BASE_URL=http://localhost:3009
